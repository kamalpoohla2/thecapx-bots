# ── Content Publishing (All Free) ─────────────────────────────────
# Medium: https://medium.com/me/settings → Integration tokens
MEDIUM_TOKEN=your_medium_integration_token

# Dev.to: https://dev.to/settings/extensions → DEV API Keys
DEVTO_API_KEY=your_devto_api_key

# Hashnode: https://hashnode.com/settings/developer → Access Token
HASHNODE_TOKEN=your_hashnode_token
HASHNODE_PUBLICATION_ID=your_publication_id

# ── Analytics (Free) ──────────────────────────────────────────────
# Google Analytics 4 → Admin → Data Streams → Measurement ID
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Service Account JSON key (for server-side GA4 data)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# ── Notifications (Free) ──────────────────────────────────────────
# Brevo free email (300/day): https://brevo.com
BREVO_API_KEY=your_brevo_api_key
NOTIFICATION_EMAIL=your_email@gmail.com

# ── Target Site (auto-loaded from config.json but can override) ────
TARGET_SITE_URL=https://www.thecapx.in
SITE_NAME=CapX
